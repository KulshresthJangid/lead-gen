# Server
PORT=3001
DB_TYPE=sqlite
DATABASE_URL=postgres://user:pass@localhost:5432/leadgen
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info
NODE_ENV=development

# Auth (hardcoded credentials — change these in production)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
JWT_SECRET=change-me-to-a-long-random-string

# Client (Vite)
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001
