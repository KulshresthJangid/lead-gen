# Server
PORT=3001
DB_TYPE=sqlite
DATABASE_URL=postgres://user:pass@localhost:5432/leadgen
ALLOWED_ORIGINS=http://localhost:3000
LOG_LEVEL=info
NODE_ENV=development

# Auth (hardcoded credentials — change these in production)
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
JWT_SECRET=change-me-to-a-long-random-string

# Client (Vite)
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001

# ── Outreach (secret email sending route) ────────────────────────────────────
# Password required to call POST /api/outreach/send and /api/outreach/preview
OUTREACH_SECRET=drip-secret-2026

# SMTP settings (any provider: Gmail, Resend, Postmark, etc.)
# For Gmail: enable App Passwords, set SMTP_USER=your@gmail.com, SMTP_PASS=app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
OUTREACH_FROM=Kulshresth <your@gmail.com>
